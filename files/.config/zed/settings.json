// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "prettier": {
    "allowed": true
  },
  "terminal": {
    "font_size": 18.0
  },
  "server_url": "https://zed.dev",
  "feature_flags": {
    
  },
  "proxy": "",
  "disable_ai": true,
  "scrollbar": {
    "show": "always"
  },
  "horizontal_scroll_margin": 7.0,
  "scroll_sensitivity": 4.0,
  "vertical_scroll_margin": 5.0,
  "instrumentation": {
    "performance_profiler": {
      "enabled": false
    }
  },
  "restore_on_startup": "empty_tab",
  "auto_update": false,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "which_key": {
    "delay_ms": 992
  },
  "drag_and_drop_selection": {
    "delay": 200
  },
  "hover_popover_delay": 200,
  "text_rendering_mode": "subpixel",
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "default": "confirm",
          "always_allow": [{ "pattern": "^cargo\\s+(build|test|check)" }, { "pattern": "^npm\\s+(install|test|run)" }],
          "always_confirm": [{ "pattern": "sudo\\s+/" }]
        }
      }
    }
  },
  "session": {
    "trust_all_worktrees": true
  },
  "tab_bar": {
    "show": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "edit_predictions": {
    "ollama": {
      "model": "qwen2.5-coder:7b"
    },
    "provider": "ollama",
    "mode": "subtle",
    "disabled_globs": [
      "**/.env*",
      "**/*.pem",
      "**/*.key",
      "**/*.cert",
      "**/*.crt",
      "**/secrets.yml",
      "**/node_modules/**/*",
      "**/*.log"
    ]
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 20,
  "ui_font_family": "PragmataPro",
  "ui_font_weight": 700,
  "buffer_font_family": "PragmataPro Mono",
  "buffer_font_weight": 100,
  "buffer_font_size": 20,
  "theme": "Moonfly"
}
